<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>RKP Search</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: linear-gradient(135deg, #0f0f0f, #1a1a2e);
    color: white;
    text-align: center;
}

/* TOP NAV */
.top-bar {
    display: flex;
    justify-content: space-between;
    padding: 15px 30px;
}

.tabs span {
    margin-right: 20px;
    cursor: pointer;
    opacity: 0.6;
}

.tabs span.active {
    border-bottom: 2px solid #00ffe0;
    opacity: 1;
}

/* TITLE */
.title {
    margin-top: 60px;
    font-size: 60px;
    color: #00ffe0;
    text-shadow: 0 0 20px #00ffe0;
}

/* SEARCH BOX */
.search-box input {
    width: 60%;
    padding: 15px;
    border-radius: 30px;
    border: none;
    outline: none;
    font-size: 18px;
}

.search-btn {
    padding: 15px 20px;
    margin-left: 10px;
    border-radius: 30px;
    border: none;
    background: #00ffe0;
    cursor: pointer;
}

/* BUTTONS */
button {
    margin: 6px;
    padding: 10px 14px;
    border-radius: 20px;
    border: none;
    background: #222;
    color: white;
    cursor: pointer;
}

button:hover {
    background: #00ffe0;
    color: black;
}

.section {
    display: none;
    margin-top: 30px;
}

.active-section {
    display: block;
}

.engines span {
    margin: 10px;
    cursor: pointer;
    color: #aaa;
}

.engines span:hover {
    color: #00ffe0;
}
</style>
</head>

<body>

<div class="top-bar">
    <div class="tabs">
        <span id="tabKeyword" class="active" onclick="switchTab('keyword')">Keyword</span>
        <span id="tabImage" onclick="switchTab('image')">Image</span>
    </div>
</div>

<div class="title">RKP Search</div>

<div class="search-box">
    <input type="text" id="query" placeholder="Search anything...">
    <button class="search-btn" onclick="normalSearch()">🔍</button>
</div>

<!-- KEYWORD SECTION -->
<div id="keywordSection" class="section active-section">

<h3>Platforms</h3>

<button onclick="searchSite('')">Normal Search</button>
<button onclick="searchSite('site:t.me')">Telegram</button>
<button onclick="searchSite('site:archive.org')">Archive</button>
<button onclick="searchSite('site:drive.google.com')">Drive</button>
<button onclick="searchSite('site:dailymotion.com')">Dailymotion</button>
<button onclick="searchSite('site:youtube.com')">YouTube</button>
<button onclick="searchSite('site:bilibili.com')">Bilibili</button>
<button onclick="searchSite('site:youku.com')">Youku</button>
<button onclick="searchSite('site:v.qq.com')">Tencent</button>

<h3>Movie Sites</h3>

<button onclick="openLink('https://www.google.com/search?q=moviehub')">moviehub</button>
<button onclick="openLink('https://www.google.com/search?q=hdhub4u')">hdhub4u</button>
<button onclick="openLink('https://www.google.com/search?q=mkvcinema')">mkvcinema</button>
<button onclick="openLink('https://www.google.com/search?q=movies4u')">movies4u</button>
<button onclick="openLink('https://www.google.com/search?q=moviesflix')">moviesflix</button>
<button onclick="openLink('https://www.google.com/search?q=mkvcinemas')">mkvcinemas</button>
<button onclick="openLink('https://www.google.com/search?q=hdmoviehub')">hdmoviehub</button>
<button onclick="openLink('https://www.google.com/search?q=mp4moviez')">mp4moviez</button>

</div>

<!-- IMAGE SECTION -->
<div id="imageSection" class="section">

<h3>Find Similar Images</h3>
<button onclick="openLink('https://images.google.com/')">Google Images</button>
<button onclick="openLink('https://www.microsoft.com/en-us/bing/visual-search/')">Bing Visual</button>
<button onclick="openLink('https://yandex.com/images/')">Yandex</button>

<h3>Where is this photo taken?</h3>
<button onclick="openLink('https://www.whereisthisphoto.com/')">WhereIsThisPhoto</button>
<button onclick="openLink('https://picarta.ai/')">Picarta</button>

<h3>Metadata Finder</h3>
<button onclick="openLink('https://tool.geoimgr.com/')">GeoImgr</button>
<button onclick="openLink('https://exiftools.com/')">ExifTools</button>
<button onclick="openLink('https://exif.tools/')">Exif.tools</button>

<h3>Advanced Image Search</h3>
<button onclick="openLink('https://www.google.com/advanced_image_search')">Google Advanced</button>

</div>

<!-- SEARCH ENGINES -->
<div class="engines">
    <p>Search Engines:</p>
    <span onclick="redirectEngine('https://www.google.com/search?q=')">Google</span>
    <span onclick="redirectEngine('https://in.search.yahoo.com/search?p=')">Yahoo</span>
    <span onclick="redirectEngine('https://yandex.com/search/?text=')">Yandex</span>
    <span onclick="redirectEngine('https://www.baidu.com/s?wd=')">Baidu</span>
    <span onclick="redirectEngine('https://www.bing.com/search?q=')">Bing</span>
    <span onclick="redirectEngine('https://duckduckgo.com/?q=')">DuckDuckGo</span>
    <span onclick="redirectEngine('https://www.naver.com/search.naver?query=')">Naver</span>
</div>

<script>
function getQuery() {
    return document.getElementById("query").value;
}

function normalSearch() {
    let q = getQuery();
    if(q) window.open("https://www.google.com/search?q=" + q);
}

function searchSite(site) {
    let q = getQuery();
    if(!q) return;

    let finalQuery = site ? q + " " + site : q;
    window.open("https://www.google.com/search?q=" + finalQuery);
}

function redirectEngine(base) {
    let q = getQuery();
    if(q) window.open(base + q);
}

function openLink(url) {
    window.open(url);
}

function switchTab(tab) {
    document.getElementById("keywordSection").classList.remove("active-section");
    document.getElementById("imageSection").classList.remove("active-section");
    document.getElementById("tabKeyword").classList.remove("active");
    document.getElementById("tabImage").classList.remove("active");

    if(tab === "keyword") {
        document.getElementById("keywordSection").classList.add("active-section");
        document.getElementById("tabKeyword").classList.add("active");
    } else {
        document.getElementById("imageSection").classList.add("active-section");
        document.getElementById("tabImage").classList.add("active");
    }
}
</script>

</body>
</html>
