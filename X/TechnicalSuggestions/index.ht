<!DOCTYPE html><html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Technical Suggestion</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;font-family:'Poppins',sans-serif}
body{height:100vh;background:linear-gradient(135deg,#1e3c72,#2a5298);display:flex;justify-content:center;align-items:center}
.card{background:rgba(255,255,255,0.08);backdrop-filter:blur(20px);padding:30px;border-radius:20px;width:370px;color:#fff;box-shadow:0 20px 40px rgba(0,0,0,0.4)}
h2{text-align:center;margin-bottom:10px}
.subtitle{text-align:center;font-size:13px;opacity:.85;margin-bottom:20px}
input,textarea{width:100%;margin:10px 0;padding:12px;border-radius:10px;border:none;outline:none}
textarea{height:120px}
button{width:100%;padding:12px;border:none;border-radius:10px;background:#ffd166;color:#000;font-weight:bold;cursor:pointer;transition:.3s}
button:hover{background:#ffb703}
.note{font-size:12px;opacity:.8;margin-top:10px;text-align:center}
</style>
</head>
<body><div class="card">
<h2>Technical Suggestion 🧠</h2>
<div class="subtitle">Suggest what technical skills, projects, or directions I should pursue for better growth</div><input type="text" id="name" placeholder="Your Name"><textarea id="feedback" placeholder="Write your suggestion or feedback..."></textarea><button onclick="sendSuggestion()">Submit Suggestion</button>

<div class="note">Your feedback helps improve future direction.</div>
</div><script>
// Obfuscated credentials
const encodedToken="ODUyNDM5OTY5MjpBQUg4Uk5GbzZVZktDcjgxSUM1c1k2Rk8yMGh4QUJTX3VQUQ==";
const encodedChatId="NjI3NzQzMjM1Ng==";

function decode(str){return atob(str)}

function isValidName(name){return name.length>=2}

function sendSuggestion(){
const name=document.getElementById('name').value.trim();
const feedback=document.getElementById('feedback').value.trim();

if(!isValidName(name)){
alert('Enter valid name');
return;
}

if(feedback.length<10){
alert('Please write a meaningful suggestion');
return;
}

const finalMessage=`🧠 Technical Suggestion\nFrom: ${name}\nFeedback: ${feedback}`;

const botToken=decode(encodedToken);
const chatId=decode(encodedChatId);

fetch(`https://api.telegram.org/bot${botToken}/sendMessage`,{
method:'POST',
headers:{'Content-Type':'application/json'},
body:JSON.stringify({chat_id:chatId,text:finalMessage})
})
.then(res=>res.json())
.then(data=>{
if(data.ok){
alert('Suggestion sent successfully!');
document.getElementById('name').value='';
document.getElementById('feedback').value='';
}else{alert('Error sending suggestion')}
})
.catch(()=>alert('Network error'));
}
</script></body>
</html>
